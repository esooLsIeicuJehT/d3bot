        lbl(right,
            "Tick 'Enable Profiler' on Control tab.\nStart bot → run for a bit → click Refresh.",
            fg=DIM_FG, font=FONT_SMALL).pack(padx=12, pady=(0,6), anchor="w")

        self._prof_text = tk.Text(right, height=18, font=FONT_LOG,
